{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/api-snap/refs/heads/main/json-structure/meta-url-metadata-structure.json",
  "name": "UrlMetadata",
  "description": "URL metadata including Open Graph tags, favicon, theme color, and authorship",
  "type": "object",
  "properties": {
    "url": {
      "type": "uri"
    },
    "title": {
      "type": "string",
      "nullable": true
    },
    "description": {
      "type": "string",
      "nullable": true
    },
    "image": {
      "type": "uri",
      "nullable": true
    },
    "siteName": {
      "type": "string",
      "nullable": true
    },
    "type": {
      "type": "string",
      "nullable": true
    },
    "favicon": {
      "type": "uri",
      "nullable": true
    },
    "themeColor": {
      "type": "string",
      "nullable": true
    },
    "author": {
      "type": "string",
      "nullable": true
    },
    "published": {
      "type": "datetime",
      "nullable": true
    }
  }
}